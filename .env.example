# Copy this file to .env if you need to point the frontend at a backend
# running on a different host/port (e.g. in production with separate
# frontend/backend deployments). For local development you can usually
# leave this unset — the CRA "proxy" setting in package.json already
# forwards /api requests to http://localhost:5000.
#
# This file contains NO secrets and is safe to commit.

REACT_APP_API_BASE_URL=
