# Optional: only needed if you want the web_search tool to work.
# Get a free key at https://serpapi.com, then copy this file to .env
# and fill it in. Without it, web_search will just report that it
# isn't configured, instead of crashing.
#
# This file (.env.example) has no real secret and is safe to commit.
#
# NOTE: like any REACT_APP_* variable, this gets baked into the built
# JS bundle — anyone who inspects the deployed app can see it. Only use
# a SerpAPI key here that you're comfortable being public (e.g. a free
# tier key with no billing attached), the same way the main Anthropic
# key you type into the app's setup screen is exposed during your
# browser session. See the "How It Works" page for the full explanation.

REACT_APP_SERPAPI_API_KEY=

# RAG API (.NET 10) — default local port
REACT_APP_RAG_API_URL=http://localhost:5001
