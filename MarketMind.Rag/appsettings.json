{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Name": "marketmind_rag"
  },
  "ConnectionStrings": {
    "PostgresMaster": "Host=localhost;Port=5432;Database=postgres;Username=postgres;Password=",
    "Postgres": "Host=localhost;Port=5432;Database=marketmind_rag;Username=postgres;Password="
  },
  "OpenRouter": {
    "ApiKey": "",
    "EmbeddingModel": "openai/text-embedding-3-small"
  },
  "Rag": {
    "SimilarityThreshold": 0.5,
    "MaxResults": 5,
    "ChunkSize": 600,
    "ChunkOverlap": 100
  }
}
