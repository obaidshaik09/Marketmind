# Copy this file to server/.env and fill in your real key.
# This file (.env.example) is safe to commit — it has no real secrets.
# server/.env is git-ignored and must NEVER be committed.

# Your Anthropic API key (starts with "sk-ant-")
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Your SerpAPI key, used by the web_search tool (free tier available at serpapi.com)
# Optional: if left blank, the agent still works but web_search will return
# a message saying the tool isn't configured, instead of search results.
SERPAPI_API_KEY=your-serpapi-key-here

# Port the backend proxy server runs on
PORT=5000
